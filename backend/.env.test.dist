# Test environment configuration template
# Copy this file to .env.test and fill in your values
# DO NOT commit .env.test - it should contain your actual test secrets

KERNEL_CLASS='App\Kernel'
APP_ENV=test
APP_SECRET='change_this_secret_for_tests'
DATABASE_URL="postgresql://pryvora:pryvora@db:5432/pryvora_test?serverVersion=16&charset=utf8"

# Test encryption key - Generate with: openssl rand -base64 32
PRYVORA_ENCRYPTION_KEY=your_test_encryption_key_here_32_chars

# JWT configuration (keys are generated in Docker container)
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=your_test_jwt_passphrase_here

# Frontend configuration
FRONTEND_URL=http://localhost:5173
DEFAULT_URI=http://localhost
COOKIE_SECURE=0
